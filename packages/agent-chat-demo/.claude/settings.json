{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Task",
      "Bash(node *)",
      "Bash(pnpm *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "WebFetch(*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "docs.anthropic.com",
        "platform.claude.com",
        "github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowRead": ["."],
      "allowWrite": ["."]
    }
  }
}
